###
# @name SubmitSimpleJob Azure
# This job has minimal configuration, relying on "auto" modes.
# It uses the S3 credentials saved via credentials.http.
POST {{api_v1}}/jobs
Content-Type: application/json

{
  "job_label": "Simple Automated Job - {{$timestamp}}",
  "job_id": "{{job_id}}",
  "input_storage": {
    "input_id": "source-{{job_id}}",
    "provider": "azure",
    "azure": {
      "container": "media-developement-1",
      "key": "test-veryfast.mp4"
    }
  },
  "output_storage": {
    "output_id": "dest-{{job_id}}",
    "provider": "azure",
    "azure": {
      "container": "media-developement-1",
      "key": "videos/simple/{{job_id}}"
    }
  },
  "job_settings": {
    "hardware_acceleration": "auto"
  },
  "outputs": {
    "streaming_package": {
      "enable": true,
      "video": {
        "encoder": "h264_nvenc",
        "renditions": []
      },
      "audio": { "mode": "auto" },
      "subtitles": { "mode": "auto" },
      "packaging": {
        "segment_duration_seconds": 2,
        "formats": ["dash", "hls"]
      }
    },
    "thumbnail": {
      "enable": true,
      "format": "vtt_sprite",
      "interval_seconds": 10,
      "dimensions": { "width": 160 }
    }
  }
}